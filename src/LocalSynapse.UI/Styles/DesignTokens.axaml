<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════ -->
    <!-- Background Colors                      -->
    <!-- ══════════════════════════════════════ -->
    <Color x:Key="BgPrimary">#FAFBFC</Color>
    <Color x:Key="BgSurface">#FFFFFF</Color>
    <Color x:Key="BgMuted">#F1F3F5</Color>
    <Color x:Key="BgHover">#F5F7FA</Color>
    <Color x:Key="BgSelected">#EFF6FF</Color>
    <Color x:Key="BgBadge">#F0F1F3</Color>
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
    <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
    <SolidColorBrush x:Key="BgMutedBrush" Color="{StaticResource BgMuted}" />
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}" />
    <SolidColorBrush x:Key="BgSelectedBrush" Color="{StaticResource BgSelected}" />
    <SolidColorBrush x:Key="BgBadgeBrush" Color="{StaticResource BgBadge}" />

    <!-- ══════════════════════════════════════ -->
    <!-- Text Colors                            -->
    <!-- ══════════════════════════════════════ -->
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="TextMuted">#9CA3AF</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

    <!-- ══════════════════════════════════════ -->
    <!-- Accent (Brand Blue — single accent)    -->
    <!-- ══════════════════════════════════════ -->
    <Color x:Key="Accent">#2563EB</Color>
    <Color x:Key="AccentLight">#EFF6FF</Color>
    <Color x:Key="AccentMuted">#BFDBFE</Color>
    <Color x:Key="AccentHover">#1D4ED8</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLight}" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />

    <!-- ══════════════════════════════════════ -->
    <!-- Semantic Colors                        -->
    <!-- ══════════════════════════════════════ -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="SuccessLight">#ECFDF5</Color>
    <Color x:Key="Warning">#D97706</Color>
    <Color x:Key="WarningLight">#FFFBEB</Color>
    <Color x:Key="Danger">#DC2626</Color>
    <Color x:Key="DangerLight">#FEF2F2</Color>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLight}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLight}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource DangerLight}" />

    <!-- ══════════════════════════════════════ -->
    <!-- Border                                 -->
    <!-- ══════════════════════════════════════ -->
    <Color x:Key="Border">#E5E7EB</Color>
    <Color x:Key="BorderSubtle">#F0F1F3</Color>
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource Border}" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource AccentMuted}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource Accent}" />
    <x:Double x:Key="BorderThickness">1</x:Double>

    <!-- ══════════════════════════════════════ -->
    <!-- File Type Colors — UNIFIED NEUTRAL     -->
    <!-- All file types use the same gray badge -->
    <!-- Only folders use brand blue            -->
    <!-- ══════════════════════════════════════ -->
    <SolidColorBrush x:Key="FileFolderBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="FileFolderBgBrush" Color="{StaticResource AccentLight}" />
    <SolidColorBrush x:Key="FileGenericBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="FileGenericBgBrush" Color="{StaticResource BgBadge}" />
    <!-- Legacy keys — all mapped to generic neutral -->
    <SolidColorBrush x:Key="FilePdfBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="FilePdfBgBrush" Color="{StaticResource BgBadge}" />
    <SolidColorBrush x:Key="FileDocBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="FileDocBgBrush" Color="{StaticResource BgBadge}" />
    <SolidColorBrush x:Key="FileXlsBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="FileXlsBgBrush" Color="{StaticResource BgBadge}" />
    <SolidColorBrush x:Key="FilePptBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="FilePptBgBrush" Color="{StaticResource BgBadge}" />

    <!-- ══════════════════════════════════════ -->
    <!-- Navigation                             -->
    <!-- ══════════════════════════════════════ -->
    <SolidColorBrush x:Key="NavBgBrush" Color="{StaticResource BgMuted}" />
    <SolidColorBrush x:Key="NavActiveBgBrush" Color="{StaticResource AccentLight}" />

    <!-- ══════════════════════════════════════ -->
    <!-- Typography                             -->
    <!-- ══════════════════════════════════════ -->
    <FontFamily x:Key="FontDefault">avares://Avalonia.Fonts.Inter/Assets#Inter, Segoe UI Variable, Segoe UI, -apple-system, Helvetica Neue, sans-serif</FontFamily>
    <FontFamily x:Key="FontMono">Cascadia Code, Consolas, Menlo, SF Mono, monospace</FontFamily>
    <x:Double x:Key="FontSizeL">20</x:Double>
    <x:Double x:Key="FontSizeM">14</x:Double>
    <x:Double x:Key="FontSizeBody">13</x:Double>
    <x:Double x:Key="FontSizeS">12</x:Double>
    <x:Double x:Key="FontSizeXs">11</x:Double>
    <x:Double x:Key="FontSizeXxs">10</x:Double>
    <x:Double x:Key="FontSizeNav">9</x:Double>

    <!-- ══════════════════════════════════════ -->
    <!-- Spacing                                -->
    <!-- ══════════════════════════════════════ -->
    <x:Double x:Key="SpacingXs">4</x:Double>
    <x:Double x:Key="SpacingSm">8</x:Double>
    <x:Double x:Key="SpacingMd">12</x:Double>
    <x:Double x:Key="SpacingLg">16</x:Double>
    <x:Double x:Key="SpacingXl">24</x:Double>
    <x:Double x:Key="SpacingXxl">32</x:Double>

    <!-- ══════════════════════════════════════ -->
    <!-- Corner Radius                          -->
    <!-- ══════════════════════════════════════ -->
    <CornerRadius x:Key="RadiusSm">6</CornerRadius>
    <CornerRadius x:Key="RadiusMd">8</CornerRadius>
    <CornerRadius x:Key="RadiusLg">10</CornerRadius>
    <CornerRadius x:Key="RadiusXl">12</CornerRadius>
    <CornerRadius x:Key="RadiusPill">100</CornerRadius>

    <!-- ══════════════════════════════════════ -->
    <!-- Sizing                                 -->
    <!-- ══════════════════════════════════════ -->
    <x:Double x:Key="NavWidth">56</x:Double>
    <x:Double x:Key="NavItemSize">40</x:Double>
    <x:Double x:Key="NavIconSize">20</x:Double>
    <x:Double x:Key="FileIconSize">34</x:Double>
    <x:Double x:Key="DetailPanelWidth">300</x:Double>
    <x:Double x:Key="SearchBarHeight">42</x:Double>
    <x:Double x:Key="ProgressBarHeight">6</x:Double>
    <x:Double x:Key="StatusDotSize">6</x:Double>
    <x:Double x:Key="ModelIconSize">36</x:Double>
    <Thickness x:Key="NavIndicatorThickness">3,0,0,0</Thickness>

</ResourceDictionary>
