<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalSynapse.UI.ViewModels"
             xmlns:i18n="using:LocalSynapse.UI.Markup"
             x:Class="LocalSynapse.UI.Views.DataSetupPage"
             x:DataType="vm:DataSetupViewModel"
             FontFamily="{StaticResource FontDefault}">

    <ScrollViewer Margin="20,24"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" MaxWidth="720">

            <!-- Header -->
            <StackPanel Spacing="4" Margin="0,0,0,4">
                <TextBlock Text="{i18n:Tr Key=Data.Header}"
                           FontSize="{StaticResource FontSizeL}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="{i18n:Tr Key=Data.Subtitle}"
                           FontSize="{StaticResource FontSizeS}"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Scan Folders Card                          -->
            <!-- ═══════════════════════════════════════════ -->
            <Border Classes="Card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="SectionHeader" Text="SCAN FOLDERS"/>

                    <TextBlock IsVisible="{Binding IsUsingDefaults}" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Default: scanning all fixed drives. Add folders below to customize."/>

                    <ItemsControl ItemsSource="{Binding ScanFolders}" Name="DataScanFolderList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="StatCard" Padding="8,6" Margin="0,0,0,4">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="✕" Padding="6,2"
                                                Classes="BtnSecondary" FontSize="11"
                                                Command="{Binding #DataScanFolderList.DataContext.RemoveFolderCommand}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="BtnSecondary" Content="+ Add Folder"
                                Command="{Binding AddFolderCommand}"/>
                        <Button Classes="BtnSecondary" Content="Reset to Default"
                                Command="{Binding ResetToDefaultsCommand}"
                                IsVisible="{Binding !IsUsingDefaults}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Indexing Performance Card                   -->
            <!-- ═══════════════════════════════════════════ -->
            <Border Classes="Card">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M13 2.05v2.02c3.95.49 7 3.85 7 7.93 0 1.45-.39 2.81-1.06 3.98l1.73 1C21.52 15.13 22 13.12 22 11c0-5.18-3.95-9.45-9-9.95zM12 19c-3.87 0-7-3.13-7-7 0-3.53 2.61-6.43 6-6.92V3.03c-4.06.5-7.18 3.91-7.18 7.97 0 4.42 3.58 8 8 8 1.94 0 3.72-.69 5.1-1.85l-1.42-1.43A5.946 5.946 0 0 1 12 19zm1-9V7l-4 4 4 4v-3c1.65 0 3 1.35 3 3s-1.35 3-3 3v2c2.76 0 5-2.24 5-5s-2.24-5-5-5z" />
                        <TextBlock Text="{i18n:Tr Key=Settings.Performance.Title}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>
                    <TextBlock Text="{i18n:Tr Key=Settings.Performance.Subtitle}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <WrapPanel Orientation="Horizontal">
                        <Button Content="{i18n:Tr Key=Settings.Performance.Stealth.Label}"
                                Classes.BtnPrimary="{Binding IsStealthSelected}"
                                Classes.BtnSecondary="{Binding !IsStealthSelected}"
                                Command="{Binding ChangePerformanceModeCommand}" CommandParameter="Stealth"
                                Margin="0,0,8,4" />
                        <Button Content="{i18n:Tr Key=Settings.Performance.Cruise.Label}"
                                Classes.BtnPrimary="{Binding IsCruiseSelected}"
                                Classes.BtnSecondary="{Binding !IsCruiseSelected}"
                                Command="{Binding ChangePerformanceModeCommand}" CommandParameter="Cruise"
                                Margin="0,0,8,4" />
                        <Button Content="{i18n:Tr Key=Settings.Performance.Overdrive.Label}"
                                Classes.BtnPrimary="{Binding IsOverdriveSelected}"
                                Classes.BtnSecondary="{Binding !IsOverdriveSelected}"
                                Command="{Binding ChangePerformanceModeCommand}" CommandParameter="Overdrive"
                                Margin="0,0,8,4" />
                        <Button Content="{i18n:Tr Key=Settings.Performance.MadMax.Label}"
                                Classes.BtnPrimary="{Binding IsMadMaxSelected}"
                                Classes.BtnSecondary="{Binding !IsMadMaxSelected}"
                                IsEnabled="{Binding IsMadMaxEnabled}"
                                Command="{Binding ChangePerformanceModeCommand}" CommandParameter="MadMax"
                                Margin="0,0,8,4" />
                    </WrapPanel>
                    <Border Classes="StatCard">
                        <TextBlock Text="{Binding PerformanceModeTech}"
                                   FontSize="{StaticResource FontSizeXs}"
                                   FontFamily="{StaticResource FontMono}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </Border>
                    <TextBlock Text="{Binding PerformanceModeDesc}"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding MadMaxSubText}"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontStyle="Italic" />
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Pipeline Status Card                       -->
            <!-- ═══════════════════════════════════════════ -->
            <Border Classes="Card">
                <StackPanel Spacing="14">

                    <!-- ═══ C-4: Header + Status Badge ═══ -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h6v7h6v9H6z" />
                        <TextBlock Text="{i18n:Tr Key=Data.PipelineStatus}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />

                        <!-- Running badge -->
                        <Border Background="{StaticResource AccentLightBrush}"
                                CornerRadius="10" Padding="10,2"
                                IsVisible="{Binding IsCycleRunning}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}">
                                    <Ellipse.Styles>
                                        <Style Selector="Ellipse">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.5" IterationCount="INFINITE">
                                                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Ellipse.Styles>
                                </Ellipse>
                                <TextBlock Text="{Binding CurrentPhase}"
                                           FontSize="{StaticResource FontSizeS}"
                                           Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Ready badge -->
                        <Border Background="{StaticResource SuccessLightBrush}"
                                CornerRadius="10" Padding="10,2"
                                IsVisible="{Binding !IsCycleRunning}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" />
                                <TextBlock Text="{i18n:Tr Key=Data.Ready}"
                                           FontSize="{StaticResource FontSizeS}"
                                           Foreground="{StaticResource SuccessBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ═══ C-1: 3-Step Stepper ═══ -->
                    <Grid ColumnDefinitions="*,40,*,40,*" Margin="0,6,0,0">

                        <!-- Step 1: Scan -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="6">
                            <!-- Complete icon -->
                            <Border Width="30" Height="30" CornerRadius="15"
                                    Background="{StaticResource AccentBrush}"
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsScanComplete}">
                                <PathIcon Width="14" Height="14" Foreground="White"
                                          Data="M3.5 7.5L5.5 9.5L10.5 4.5" />
                            </Border>
                            <!-- In-progress icon (spinner) -->
                            <Border Width="30" Height="30" CornerRadius="15"
                                    Background="{StaticResource AccentBrush}"
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsScanning}">
                                <Ellipse Width="10" Height="10" Fill="White"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform><ScaleTransform /></Ellipse.RenderTransform>
                                    <Ellipse.Styles>
                                        <Style Selector="Ellipse">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1" IterationCount="INFINITE">
                                                    <KeyFrame Cue="0%"><Setter Property="ScaleTransform.ScaleX" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="0%"><Setter Property="ScaleTransform.ScaleY" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="ScaleTransform.ScaleX" Value="1.15"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="ScaleTransform.ScaleY" Value="1.15"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.7"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="ScaleTransform.ScaleX" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="ScaleTransform.ScaleY" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Ellipse.Styles>
                                </Ellipse>
                            </Border>
                            <!-- Pending icon -->
                            <Border Width="30" Height="30" CornerRadius="15"
                                    Background="Transparent" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="2"
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsScanPending}">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource TextMutedBrush}" />
                            </Border>
                            <TextBlock Text="{i18n:Tr Key=Data.Scan.Title}" FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"
                                       HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding Stamps.TotalFiles, StringFormat='{}{0:N0}'}"
                                       FontSize="{StaticResource FontSizeL}" FontWeight="Medium"
                                       HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{i18n:Tr Key=Data.Scan.FilesFound}"
                                       FontSize="{StaticResource FontSizeXs}" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>

                        <!-- Connector 1→2 -->
                        <Border Grid.Column="1" Height="2" VerticalAlignment="Top" Margin="0,14,0,0"
                                Background="{StaticResource AccentBrush}"
                                IsVisible="{Binding IsScanComplete}" />
                        <Border Grid.Column="1" Height="2" VerticalAlignment="Top" Margin="0,14,0,0"
                                Background="{StaticResource BorderDefaultBrush}"
                                IsVisible="{Binding !IsScanComplete}" />

                        <!-- Step 2: Extract -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="6">
                            <Border Width="30" Height="30" CornerRadius="15"
                                    Background="{StaticResource AccentBrush}"
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsExtractComplete}">
                                <PathIcon Width="14" Height="14" Foreground="White"
                                          Data="M3.5 7.5L5.5 9.5L10.5 4.5" />
                            </Border>
                            <Border Width="30" Height="30" CornerRadius="15"
                                    Background="{StaticResource AccentBrush}"
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsExtracting}">
                                <Ellipse Width="10" Height="10" Fill="White"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform><ScaleTransform /></Ellipse.RenderTransform>
                                    <Ellipse.Styles>
                                        <Style Selector="Ellipse">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1" IterationCount="INFINITE">
                                                    <KeyFrame Cue="0%"><Setter Property="ScaleTransform.ScaleX" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="0%"><Setter Property="ScaleTransform.ScaleY" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="ScaleTransform.ScaleX" Value="1.15"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="ScaleTransform.ScaleY" Value="1.15"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.7"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="ScaleTransform.ScaleX" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="ScaleTransform.ScaleY" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Ellipse.Styles>
                                </Ellipse>
                            </Border>
                            <Border Width="30" Height="30" CornerRadius="15"
                                    Background="Transparent" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="2"
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsExtractPending}">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource TextMutedBrush}" />
                            </Border>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{i18n:Tr Key=Data.Extract.Title}" FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{i18n:Tr Key=Data.Extract.Subtitle}" FontSize="{StaticResource FontSizeXxs}"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Stamps.TotalChunks, StringFormat='{}{0:N0}'}"
                                       FontSize="{StaticResource FontSizeL}" FontWeight="Medium"
                                       HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{i18n:Tr Key=Data.Extract.Chunks}" FontSize="{StaticResource FontSizeXs}" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>

                        <!-- Connector 2→3 -->
                        <Border Grid.Column="3" Height="2" VerticalAlignment="Top" Margin="0,14,0,0"
                                Background="{StaticResource AccentBrush}"
                                IsVisible="{Binding IsExtractComplete}" />
                        <Border Grid.Column="3" Height="2" VerticalAlignment="Top" Margin="0,14,0,0"
                                Background="{StaticResource BorderDefaultBrush}"
                                IsVisible="{Binding !IsExtractComplete}" />

                        <!-- Step 3: Embed -->
                        <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="6">
                            <Border Width="30" Height="30" CornerRadius="15"
                                    Background="{StaticResource AccentBrush}"
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsEmbedComplete}">
                                <PathIcon Width="14" Height="14" Foreground="White"
                                          Data="M3.5 7.5L5.5 9.5L10.5 4.5" />
                            </Border>
                            <Border Width="30" Height="30" CornerRadius="15"
                                    Background="{StaticResource AccentBrush}"
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsEmbedding}">
                                <Ellipse Width="10" Height="10" Fill="White"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform><ScaleTransform /></Ellipse.RenderTransform>
                                    <Ellipse.Styles>
                                        <Style Selector="Ellipse">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1" IterationCount="INFINITE">
                                                    <KeyFrame Cue="0%"><Setter Property="ScaleTransform.ScaleX" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="0%"><Setter Property="ScaleTransform.ScaleY" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="ScaleTransform.ScaleX" Value="1.15"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="ScaleTransform.ScaleY" Value="1.15"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.7"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="ScaleTransform.ScaleX" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="ScaleTransform.ScaleY" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Ellipse.Styles>
                                </Ellipse>
                            </Border>
                            <Border Width="30" Height="30" CornerRadius="15"
                                    Background="Transparent" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="2"
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsEmbedPending}">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource TextMutedBrush}" />
                            </Border>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{i18n:Tr Key=Data.Embed.Title}" FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{i18n:Tr Key=Data.Embed.Subtitle}" FontSize="{StaticResource FontSizeXxs}"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Stamps.EmbeddingPercent, StringFormat='{}{0:F1}%'}"
                                       FontSize="{StaticResource FontSizeL}" FontWeight="Medium"
                                       HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{i18n:Tr Key=Data.Embed.Stat}" FontSize="{StaticResource FontSizeXs}" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Grid>

                    <!-- ═══ C-2: Progress Bar ═══ -->
                    <!-- Scanning: indeterminate -->
                    <ProgressBar IsIndeterminate="True" Height="3" CornerRadius="1.5"
                                 Foreground="{StaticResource AccentBrush}" Background="{StaticResource BorderSubtleBrush}"
                                 IsVisible="{Binding IsScanning}" />
                    <!-- Extracting: determinate -->
                    <ProgressBar IsIndeterminate="False" Value="{Binding ExtractProgress}" Maximum="100"
                                 Height="3" CornerRadius="1.5"
                                 Foreground="{StaticResource AccentBrush}" Background="{StaticResource BorderSubtleBrush}"
                                 IsVisible="{Binding IsExtracting}" />
                    <!-- Embedding: determinate -->
                    <ProgressBar IsIndeterminate="False" Value="{Binding EmbedProgress}" Maximum="100"
                                 Height="3" CornerRadius="1.5"
                                 Foreground="{StaticResource AccentBrush}" Background="{StaticResource BorderSubtleBrush}"
                                 IsVisible="{Binding IsEmbedding}" />

                    <!-- ═══ C-3: Status Text ═══ -->
                    <TextBlock Text="{Binding PipelineStatusText}"
                               FontSize="{StaticResource FontSizeXs}"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <!-- ═══ Action Buttons ═══ -->
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <Button Classes="BtnSecondary"
                                Content="{i18n:Tr Key=Data.ScanNow}"
                                Command="{Binding ScanNowCommand}"
                                IsEnabled="{Binding !IsCycleRunning}" />
                        <Button Classes="BtnSecondary"
                                Content="{i18n:Tr Key=Data.Pause}"
                                Command="{Binding PausePipelineCommand}"
                                IsVisible="{Binding !IsPipelinePaused}" />
                        <Button Classes="BtnSecondary"
                                Content="{i18n:Tr Key=Data.Resume}"
                                Command="{Binding ResumePipelineCommand}"
                                IsVisible="{Binding IsPipelinePaused}" />
                    </StackPanel>

                    <!-- ═══ C-5: Skipped Files Info Box ═══ -->
                    <StackPanel Spacing="10" Margin="0,12,0,0" IsVisible="{Binding HasSkippedFiles}">
                        <Border Height="1" Background="{StaticResource BorderSubtleBrush}" />
                        <Border Background="{StaticResource WarningLightBrush}"
                                CornerRadius="{StaticResource RadiusMd}"
                                Padding="16,12">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="14" Height="14" Stroke="{StaticResource WarningBrush}"
                                             StrokeThickness="1.2" Fill="Transparent" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   Text="{Binding SkippedFiles, Mode=OneWay, StringFormat='{}{0:N0}'}" />
                                        <TextBlock FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   Text="{i18n:Tr Key=Data.FilesSkippedSuffix}" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="{i18n:Tr Key=Data.SkippedInfo}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ═══ C-6: Scan Info Section ═══ -->
                    <StackPanel Spacing="10" Margin="0,6,0,0">
                        <!-- Auto-scan -->
                        <DockPanel>
                            <Ellipse DockPanel.Dock="Left" Width="14" Height="14"
                                     Stroke="{StaticResource BorderDefaultBrush}" StrokeThickness="1"
                                     Fill="Transparent" Margin="0,1,10,0" VerticalAlignment="Top" />
                            <StackPanel Spacing="2">
                                <TextBlock Text="{i18n:Tr Key=Data.AutoScan.Title}"
                                           FontSize="{StaticResource FontSizeS}" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{i18n:Tr Key=Data.AutoScan.Info}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                        <!-- Manual re-scan -->
                        <DockPanel>
                            <Ellipse DockPanel.Dock="Left" Width="14" Height="14"
                                     Stroke="{StaticResource BorderDefaultBrush}" StrokeThickness="1"
                                     Fill="Transparent" Margin="0,1,10,0" VerticalAlignment="Top" />
                            <StackPanel Spacing="2">
                                <TextBlock Text="{i18n:Tr Key=Data.ManualScan.Title}"
                                           FontSize="{StaticResource FontSizeS}" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{i18n:Tr Key=Data.ManualScan.Info}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- AI Semantic Search Card                    -->
            <!-- ═══════════════════════════════════════════ -->
            <Border Classes="Card">
                <StackPanel Spacing="12">

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                        <TextBlock Text="{i18n:Tr Key=Data.AiSearchTitle}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />

                        <!-- Model status badge -->
                        <Border Background="{StaticResource WarningLightBrush}"
                                CornerRadius="{StaticResource RadiusSm}"
                                Padding="10,4">
                            <TextBlock Text="{Binding ModelStatus}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource WarningBrush}" />
                        </Border>
                    </StackPanel>

                    <!-- Model download card -->
                    <Border Classes="ModelCard">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <!-- Icon -->
                            <Border Grid.Column="0"
                                    Width="32" Height="32"
                                    CornerRadius="8"
                                    Background="{StaticResource AccentLightBrush}"
                                    Margin="0,0,12,0">
                                <PathIcon Width="16" Height="16"
                                          Foreground="{StaticResource AccentBrush}"
                                          Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                            </Border>
                            <!-- Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{i18n:Tr Key=Data.Model.Title}"
                                           FontSize="{StaticResource FontSizeS}"
                                           FontWeight="Medium" />
                                <TextBlock Text="{i18n:Tr Key=Data.Model.Subtitle}"
                                           FontSize="{StaticResource FontSizeXxs}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                            <!-- Button -->
                            <!-- H2 (M0-H): Install / ✓Installed 토글. 같은 Grid.Column, IsVisible로 전환. -->
                            <Button Grid.Column="2"
                                    Classes="BtnPrimary"
                                    Content="{i18n:Tr Key=Common.Install}"
                                    Command="{Binding DownloadModelCommand}"
                                    IsVisible="{Binding !IsModelInstalled}"
                                    VerticalAlignment="Center" />
                            <Button Grid.Column="2"
                                    Classes="BtnPrimary"
                                    Content="{i18n:Tr Key=Common.Installed}"
                                    IsEnabled="False"
                                    IsVisible="{Binding IsModelInstalled}"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>