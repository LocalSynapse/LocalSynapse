<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalSynapse.UI.ViewModels"
             xmlns:i18n="using:LocalSynapse.UI.Markup"
             x:Class="LocalSynapse.UI.Views.SecurityPage"
             x:DataType="vm:SecurityViewModel"
             FontFamily="{StaticResource FontDefault}">

    <ScrollViewer Margin="20,24"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" MaxWidth="720">

            <!-- Privacy & Security Header -->
            <StackPanel Spacing="4" Margin="0,0,0,4">
                <TextBlock Text="{i18n:Tr Key=Security.Header}"
                           FontSize="{StaticResource FontSizeL}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="{i18n:Tr Key=Security.Subtitle}"
                           FontSize="{StaticResource FontSizeS}"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- 100% Offline Guarantee -->
            <Border Background="{StaticResource SuccessLightBrush}"
                    CornerRadius="{StaticResource RadiusLg}"
                    Padding="20,16"
                    BorderThickness="0">
                <DockPanel>
                    <PathIcon DockPanel.Dock="Left" Width="22" Height="22"
                              Foreground="{StaticResource SuccessBrush}"
                              Margin="0,0,14,0" VerticalAlignment="Top"
                              Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="{i18n:Tr Key=Security.OfflineTitle}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessBrush}" />
                        <TextBlock Text="{i18n:Tr Key=Security.OfflineDescription}"
                                   TextWrapping="Wrap"
                                   FontSize="{StaticResource FontSizeS}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   Opacity="0.8" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Data Storage -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z" />
                        <TextBlock Text="{i18n:Tr Key=Security.StorageTitle}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>

                    <Border Classes="StatCard">
                        <StackPanel Spacing="6">
                            <DockPanel>
                                <TextBlock Text="{Binding StorageLocation}"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{i18n:Tr Key=Security.StorageLocation}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Width="70" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="{Binding StorageSize}"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{i18n:Tr Key=Security.StorageSize}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Width="70" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Button Classes="BtnSecondary" Content="{i18n:Tr Key=Security.OpenDataFolder}"
                            Command="{Binding OpenDataFolderCommand}" />
                </StackPanel>
            </Border>

            <!-- How It Works -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" />
                        <TextBlock Text="{i18n:Tr Key=Security.HowItWorksTitle}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeS}" />
                            <TextBlock Text="{i18n:Tr Key=Security.HowItWorks.Bullet1}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeS}" />
                            <TextBlock Text="{i18n:Tr Key=Security.HowItWorks.Bullet2}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeS}" />
                            <TextBlock Text="{i18n:Tr Key=Security.HowItWorks.Bullet3}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeS}" />
                            <TextBlock Text="{i18n:Tr Key=Security.HowItWorks.Bullet5}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeS}" />
                            <TextBlock Text="{i18n:Tr Key=Security.HowItWorks.Bullet4}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- What LocalSynapse Sends -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" />
                        <TextBlock Text="{i18n:Tr Key=Security.Sends.Title}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>

                    <TextBlock Text="{i18n:Tr Key=Security.Sends.Subtitle}"
                               FontSize="{StaticResource FontSizeS}"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <!-- Receives / Sends rows -->
                    <Border Classes="StatCard" Padding="10,8">
                        <StackPanel Spacing="6">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{i18n:Tr Key=Security.Sends.Frequency}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="⬇" FontSize="12" Foreground="{StaticResource SuccessBrush}" />
                                    <TextBlock Text="{i18n:Tr Key=Security.Sends.Receives}"
                                               FontSize="{StaticResource FontSizeXs}"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{i18n:Tr Key=Security.Sends.Frequency}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="⬆" FontSize="12" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="{i18n:Tr Key=Security.Sends.Sends}"
                                               FontSize="{StaticResource FontSizeXs}"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Toggle -->
                    <DockPanel>
                        <ToggleSwitch DockPanel.Dock="Right"
                                      IsChecked="{Binding IsExternalCommunicationEnabled}"
                                      VerticalAlignment="Center" />
                        <TextBlock Text="{i18n:Tr Key=Security.Sends.Toggle}"
                                   FontSize="{StaticResource FontSizeS}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Confirmation dialog (inline) -->
                    <Border IsVisible="{Binding ShowTurnOffConfirmation}"
                            Background="{StaticResource WarningLightBrush}"
                            CornerRadius="8" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{i18n:Tr Key=Security.Sends.ConfirmTitle}"
                                       FontSize="{StaticResource FontSizeS}" FontWeight="SemiBold" />
                            <TextBlock Text="{i18n:Tr Key=Security.Sends.ConfirmBody}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="{i18n:Tr Key=Security.Sends.ConfirmAction}"
                                        Classes="BtnSecondary" FontSize="12"
                                        Command="{Binding ConfirmTurnOffCommand}" />
                                <Button Content="{i18n:Tr Key=Security.Sends.ConfirmCancel}"
                                        Classes="BtnPrimary" FontSize="12"
                                        Command="{Binding CancelTurnOffCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Expandable ping disclosure -->
                    <Button Classes="BtnSecondary" HorizontalAlignment="Left"
                            Command="{Binding TogglePingExpandedCommand}"
                            Content="{i18n:Tr Key=Security.Sends.ExpandTitle}" FontSize="12" />

                    <TextBlock IsVisible="{Binding IsPingExpanded}"
                               Text="{i18n:Tr Key=Security.Sends.ExpandBody}"
                               FontSize="{StaticResource FontSizeXs}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,4" />

                    <Button IsVisible="{Binding IsPingExpanded}"
                            Content="{i18n:Tr Key=Security.Sends.ViewLastSent}"
                            Classes="BtnSecondary" FontSize="12"
                            Command="{Binding ViewLastSentCommand}"
                            Margin="0,0,0,4" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
