<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalSynapse.UI.ViewModels"
             xmlns:i18n="using:LocalSynapse.UI.Markup"
             x:Class="LocalSynapse.UI.Views.SecurityPage"
             x:DataType="vm:SecurityViewModel"
             FontFamily="{StaticResource FontDefault}">

    <ScrollViewer Margin="20,24"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" MaxWidth="720">

            <!-- Privacy & Security Header -->
            <StackPanel Spacing="4" Margin="0,0,0,4">
                <TextBlock Text="{i18n:Tr Key=Security.Header}"
                           FontSize="{StaticResource FontSizeL}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="{i18n:Tr Key=Security.Subtitle}"
                           FontSize="{StaticResource FontSizeS}"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- 100% Offline Guarantee -->
            <Border Background="{StaticResource SuccessLightBrush}"
                    CornerRadius="{StaticResource RadiusLg}"
                    Padding="20,16"
                    BorderThickness="0">
                <DockPanel>
                    <PathIcon DockPanel.Dock="Left" Width="22" Height="22"
                              Foreground="{StaticResource SuccessBrush}"
                              Margin="0,0,14,0" VerticalAlignment="Top"
                              Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="{i18n:Tr Key=Security.OfflineTitle}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessBrush}" />
                        <TextBlock Text="{i18n:Tr Key=Security.OfflineDescription}"
                                   TextWrapping="Wrap"
                                   FontSize="{StaticResource FontSizeS}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   Opacity="0.8" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Update check disclosure -->
            <Border Background="{StaticResource AccentLightBrush}"
                    CornerRadius="{StaticResource RadiusLg}"
                    Padding="20,16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="&#x1F4E1;"
                               FontSize="20" Margin="0,0,14,0" VerticalAlignment="Top" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="{i18n:Tr Key=Security.PingTitle}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="{i18n:Tr Key=Security.PingDescription}"
                                   TextWrapping="Wrap"
                                   FontSize="{StaticResource FontSizeS}"
                                   Foreground="{StaticResource AccentBrush}"
                                   Opacity="0.8" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Data Storage -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z" />
                        <TextBlock Text="{i18n:Tr Key=Security.StorageTitle}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>

                    <Border Classes="StatCard">
                        <StackPanel Spacing="6">
                            <DockPanel>
                                <TextBlock Text="{Binding StorageLocation}"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{i18n:Tr Key=Security.StorageLocation}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Width="70" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="{Binding StorageSize}"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{i18n:Tr Key=Security.StorageSize}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Width="70" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Button Classes="BtnSecondary" Content="{i18n:Tr Key=Security.OpenDataFolder}"
                            Command="{Binding OpenDataFolderCommand}" />
                </StackPanel>
            </Border>

            <!-- How It Works -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" />
                        <TextBlock Text="{i18n:Tr Key=Security.HowItWorksTitle}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeS}" />
                            <TextBlock Text="{i18n:Tr Key=Security.HowItWorks.Bullet1}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeS}" />
                            <TextBlock Text="{i18n:Tr Key=Security.HowItWorks.Bullet2}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeS}" />
                            <TextBlock Text="{i18n:Tr Key=Security.HowItWorks.Bullet3}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeS}" />
                            <TextBlock Text="{i18n:Tr Key=Security.HowItWorks.Bullet5}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="•" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeS}" />
                            <TextBlock Text="{i18n:Tr Key=Security.HowItWorks.Bullet4}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
