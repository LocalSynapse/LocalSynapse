<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LocalSynapse.UI.ViewModels"
        xmlns:i18n="using:LocalSynapse.UI.Markup"
        x:Class="LocalSynapse.UI.Views.AlwaysOnOnboardingDialog"
        x:DataType="vm:AlwaysOnOnboardingViewModel"
        Title="LocalSynapse"
        Width="440"
        SizeToContent="Height"
        MinHeight="280"
        MaxHeight="480"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="BorderOnly">

    <Border Padding="32" Background="{StaticResource SurfaceBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <!-- Title (localized text set in code-behind based on IsUpgrade) -->
                <TextBlock Name="TitleBlock"
                           FontSize="{StaticResource FontSizeL}"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <!-- Body -->
                <TextBlock Name="BodyBlock"
                           FontSize="{StaticResource FontSizeS}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           LineHeight="22" />

                <!-- Hotkey display -->
                <Border Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="6"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⌨"
                                   FontSize="{StaticResource FontSizeM}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding HotkeyDisplay}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium"
                                   FontFamily="{StaticResource FontMono}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                </Border>

                <!-- Auto-start checkbox -->
                <CheckBox Name="AutoStartCheck"
                          IsChecked="{Binding IsAutoStartChecked}"
                          FontSize="{StaticResource FontSizeS}" />

                <!-- Confirm button -->
                <Button Name="ConfirmButton"
                        Click="OnConfirmClick"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        FontWeight="Medium"
                        Padding="12,10"
                        Classes="accent" />
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
