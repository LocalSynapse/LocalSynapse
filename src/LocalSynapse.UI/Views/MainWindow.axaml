<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LocalSynapse.UI.ViewModels"
        xmlns:views="using:LocalSynapse.UI.Views"
        xmlns:conv="using:LocalSynapse.UI.Converters"
        xmlns:i18n="using:LocalSynapse.UI.Markup"
        x:Class="LocalSynapse.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="LocalSynapse"
        Icon="/Assets/app-icon-256.png"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}"
        FontFamily="{StaticResource FontDefault}">

    <Window.Resources>
        <conv:NavActiveConverter x:Key="NavActive" />
    </Window.Resources>

    <DockPanel>

        <!-- Left Navigation Rail (hidden during Welcome) -->
        <Border DockPanel.Dock="Left"
                Width="56"
                IsVisible="{Binding ShowNavRail}"
                Background="{StaticResource NavBgBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Top nav items -->
                <StackPanel Grid.Row="0" Margin="0,16,0,0" Spacing="4"
                            HorizontalAlignment="Stretch">

                    <!-- Search -->
                    <Grid Height="40" Margin="0,0,0,0">
                        <!-- Active indicator bar (left 3px) -->
                        <Border Width="3" HorizontalAlignment="Left"
                                CornerRadius="0,2,2,0"
                                Background="{StaticResource AccentBrush}"
                                IsVisible="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Search:Bar'}" />
                        <!-- Nav item -->
                        <Border Background="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Search:Bg'}"
                                CornerRadius="{StaticResource RadiusMd}"
                                Margin="8,0,8,0">
                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="{x:Static vm:PageType.Search}"
                                    Width="40" Height="40" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <PathIcon Width="18" Height="18"
                                              Foreground="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Search:Fg'}"
                                              Data="M15.5 14h-.79l-.28-.27a6.5 6.5 0 0 0 1.48-5.34c-.47-2.78-2.79-5-5.59-5.34a6.505 6.505 0 0 0-7.27 7.27c.34 2.8 2.56 5.12 5.34 5.59a6.5 6.5 0 0 0 5.34-1.48l.27.28v.79l4.25 4.25c.41.41 1.08.41 1.49 0 .41-.41.41-1.08 0-1.49L15.5 14zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
                                    <TextBlock Text="{i18n:Tr Key=Nav.Search}" FontSize="{StaticResource FontSizeNav}"
                                               Foreground="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Search:Fg'}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>

                    <!-- Data -->
                    <Grid Height="40">
                        <Border Width="3" HorizontalAlignment="Left"
                                CornerRadius="0,2,2,0"
                                Background="{StaticResource AccentBrush}"
                                IsVisible="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='DataSetup:Bar'}" />
                        <Border Background="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='DataSetup:Bg'}"
                                CornerRadius="{StaticResource RadiusMd}"
                                Margin="8,0,8,0">
                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="{x:Static vm:PageType.DataSetup}"
                                    Width="40" Height="40" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <PathIcon Width="18" Height="18"
                                              Foreground="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='DataSetup:Fg'}"
                                              Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                                    <TextBlock Text="{i18n:Tr Key=Nav.Data}" FontSize="{StaticResource FontSizeNav}"
                                               Foreground="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='DataSetup:Fg'}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>

                    <!-- MCP -->
                    <Grid Height="40">
                        <Border Width="3" HorizontalAlignment="Left"
                                CornerRadius="0,2,2,0"
                                Background="{StaticResource AccentBrush}"
                                IsVisible="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='McpSetup:Bar'}" />
                        <Border Background="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='McpSetup:Bg'}"
                                CornerRadius="{StaticResource RadiusMd}"
                                Margin="8,0,8,0">
                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="{x:Static vm:PageType.McpSetup}"
                                    Width="40" Height="40" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <PathIcon Width="18" Height="18"
                                              Foreground="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='McpSetup:Fg'}"
                                              Data="M8 16h8v2H8zm0-4h8v2H8zm6-10H6c-1.1 0-2 .9-2 2v16c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11z" />
                                    <TextBlock Text="{i18n:Tr Key=Nav.Mcp}" FontSize="{StaticResource FontSizeNav}"
                                               Foreground="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='McpSetup:Fg'}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>

                    <!-- Security -->
                    <Grid Height="40">
                        <Border Width="3" HorizontalAlignment="Left"
                                CornerRadius="0,2,2,0"
                                Background="{StaticResource AccentBrush}"
                                IsVisible="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Security:Bar'}" />
                        <Border Background="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Security:Bg'}"
                                CornerRadius="{StaticResource RadiusMd}"
                                Margin="8,0,8,0">
                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="{x:Static vm:PageType.Security}"
                                    Width="40" Height="40" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <PathIcon Width="18" Height="18"
                                              Foreground="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Security:Fg'}"
                                              Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" />
                                    <TextBlock Text="{i18n:Tr Key=Nav.Security}" FontSize="{StaticResource FontSizeNav}"
                                               Foreground="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Security:Fg'}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>

                </StackPanel>

                <!-- Bottom nav items (Settings) -->
                <StackPanel Grid.Row="2" Margin="0,0,0,16" Spacing="4"
                            HorizontalAlignment="Stretch">
                    <Grid Height="40">
                        <Border Width="3" HorizontalAlignment="Left"
                                CornerRadius="0,2,2,0"
                                Background="{StaticResource AccentBrush}"
                                IsVisible="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Settings:Bar'}" />
                        <!-- Update notification dot -->
                        <Ellipse Width="8" Height="8"
                                 Fill="{StaticResource DangerBrush}"
                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,2,10,0"
                                 IsVisible="{Binding HasUpdateAvailable}" />
                        <Border Background="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Settings:Bg'}"
                                CornerRadius="{StaticResource RadiusMd}"
                                Margin="8,0,8,0">
                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="{x:Static vm:PageType.Settings}"
                                    Width="40" Height="40" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <PathIcon Width="18" Height="18"
                                              Foreground="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Settings:Fg'}"
                                              Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.49.49 0 0 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6A3.6 3.6 0 1 1 12 8.4a3.6 3.6 0 0 1 0 7.2z" />
                                    <TextBlock Text="{i18n:Tr Key=Nav.Settings}" FontSize="{StaticResource FontSizeNav}"
                                               Foreground="{Binding CurrentPage, Converter={StaticResource NavActive}, ConverterParameter='Settings:Fg'}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Update banner (global, notify-only) -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding ShowUpdateBanner}"
                Background="{StaticResource AccentLightBrush}"
                Padding="20,10"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <DockPanel>
                    <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal"
                               VerticalAlignment="Center">
                        <Button Content="{Binding InstallButtonCaption}"
                                Classes.BtnPrimary="{Binding InstallButtonIsPrimary}"
                                Classes.BtnSecondary="{Binding !InstallButtonIsPrimary}"
                                FontSize="12"
                                Margin="4,0"
                                IsVisible="{Binding ShowInstallButton}"
                                IsEnabled="{Binding InstallButtonEnabled}"
                                Command="{Binding InstallUpdateCommand}" />
                        <Button Content="{i18n:Tr Key=Banner.ViewReleaseNotes}"
                                Classes="BtnSecondary" FontSize="12"
                                Margin="4,0"
                                IsEnabled="{Binding !IsInstalling}"
                                Command="{Binding ViewReleaseNotesCommand}" />
                        <Button Content="{i18n:Tr Key=Banner.Dismiss}"
                                Classes="BtnSecondary" FontSize="12"
                                Margin="4,0"
                                IsEnabled="{Binding !IsInstalling}"
                                Command="{Binding DismissBannerCommand}" />
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource AccentBrush}"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                        <TextBlock Text="{i18n:Tr Key=Banner.UpdateAvailable}"
                                   FontSize="{StaticResource FontSizeS}"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
                <TextBlock Text="{Binding InstallSubText}"
                           IsVisible="{Binding InstallSubTextVisible}"
                           Margin="28,4,0,0"
                           FontSize="{StaticResource FontSizeXs}"
                           Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Page Content -->
        <ContentControl Content="{Binding CurrentPageViewModel}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:SearchViewModel">
                    <views:SearchPage />
                </DataTemplate>
                <DataTemplate DataType="vm:DataSetupViewModel">
                    <views:DataSetupPage />
                </DataTemplate>
                <DataTemplate DataType="vm:McpViewModel">
                    <views:McpPage />
                </DataTemplate>
                <DataTemplate DataType="vm:SecurityViewModel">
                    <views:SecurityPage />
                </DataTemplate>
                <DataTemplate DataType="vm:SettingsViewModel">
                    <views:SettingsPage />
                </DataTemplate>
                <DataTemplate DataType="vm:WelcomeViewModel">
                    <views:WelcomePage />
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>

    </DockPanel>
</Window>
