<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalSynapse.UI.ViewModels"
             x:Class="LocalSynapse.UI.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             FontFamily="{StaticResource FontDefault}">

    <ScrollViewer Margin="20,24"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" MaxWidth="720">

            <!-- Header -->
            <StackPanel Spacing="4" Margin="0,0,0,4">
                <TextBlock Text="Settings"
                           FontSize="{StaticResource FontSizeL}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Configure LocalSynapse preferences"
                           FontSize="{StaticResource FontSizeS}"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- Language -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M12.87 15.07l-2.54-2.51.03-.03A17.52 17.52 0 0 0 14.07 6H17V4h-7V2H8v2H1v2h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z" />
                        <TextBlock Text="Language"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>
                    <Border Classes="StatCard">
                        <DockPanel>
                            <TextBlock Text="{Binding Language}"
                                       DockPanel.Dock="Right"
                                       FontSize="{StaticResource FontSizeXs}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Current"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </DockPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="BtnSecondary" Content="English"
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="en" />
                        <Button Classes="BtnSecondary" Content="Korean"
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="ko-KR" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" />
                        <TextBlock Text="About"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>
                    <Border Classes="StatCard">
                        <StackPanel Spacing="6">
                            <DockPanel>
                                <TextBlock Text="{Binding AppVersion}"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Version"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="{Binding DataFolder}"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="Data"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Width="60" />
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Links -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" />
                        <TextBlock Text="Links"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <Border Classes="StatCard">
                            <DockPanel>
                                <TextBlock Text="localsynapse.com"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="Website"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </DockPanel>
                        </Border>
                        <Border Classes="StatCard">
                            <DockPanel>
                                <TextBlock Text="github.com/LocalSynapse/LocalSynapse"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource AccentBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="GitHub"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </DockPanel>
                        </Border>
                        <Border Classes="StatCard">
                            <DockPanel>
                                <TextBlock Text="Apache License 2.0"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="License"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
