<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalSynapse.UI.ViewModels"
             xmlns:i18n="using:LocalSynapse.UI.Markup"
             x:Class="LocalSynapse.UI.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             FontFamily="{StaticResource FontDefault}">

    <ScrollViewer Margin="20,24"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" MaxWidth="720">

            <!-- Header -->
            <StackPanel Spacing="4" Margin="0,0,0,4">
                <TextBlock Text="{i18n:Tr Key=Settings.Header}"
                           FontSize="{StaticResource FontSizeL}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="{i18n:Tr Key=Settings.Subtitle}"
                           FontSize="{StaticResource FontSizeS}"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- First-run banner removed (WO-SEC0) — external communication defaults ON -->

            <!-- Language -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M12.87 15.07l-2.54-2.51.03-.03A17.52 17.52 0 0 0 14.07 6H17V4h-7V2H8v2H1v2h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z" />
                        <TextBlock Text="{i18n:Tr Key=Settings.Language.Title}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>
                    <Border Classes="StatCard">
                        <DockPanel>
                            <TextBlock Text="{Binding Language}"
                                       DockPanel.Dock="Right"
                                       FontSize="{StaticResource FontSizeXs}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{i18n:Tr Key=Settings.Language.Current}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </DockPanel>
                    </Border>
                    <WrapPanel Orientation="Horizontal">
                        <Button Content="English"
                                Classes.BtnPrimary="{Binding IsEnglishSelected}"
                                Classes.BtnSecondary="{Binding !IsEnglishSelected}"
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="en"
                                Margin="0,0,8,4" />
                        <Button Content="한국어"
                                Classes.BtnPrimary="{Binding IsKoreanSelected}"
                                Classes.BtnSecondary="{Binding !IsKoreanSelected}"
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="ko"
                                Margin="0,0,8,4" />
                        <Button Content="Français"
                                Classes.BtnPrimary="{Binding IsFrenchSelected}"
                                Classes.BtnSecondary="{Binding !IsFrenchSelected}"
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="fr"
                                Margin="0,0,8,4" />
                        <Button Content="Deutsch"
                                Classes.BtnPrimary="{Binding IsGermanSelected}"
                                Classes.BtnSecondary="{Binding !IsGermanSelected}"
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="de"
                                Margin="0,0,8,4" />
                        <Button Content="中文"
                                Classes.BtnPrimary="{Binding IsChineseSelected}"
                                Classes.BtnSecondary="{Binding !IsChineseSelected}"
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="zh"
                                Margin="0,0,8,4" />
                    </WrapPanel>
                    <TextBlock Text="{i18n:Tr Key=Settings.Language.SearchHint}"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- About (version status + What's new + update buttons + data + toggle) -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <!-- 헤더 -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" />
                        <TextBlock Text="{i18n:Tr Key=Settings.About.Title}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>

                    <!-- 버전 행 -->
                    <Border Classes="StatCard">
                        <DockPanel>
                            <TextBlock Text="{Binding VersionDisplay}" DockPanel.Dock="Right"
                                       FontSize="{StaticResource FontSizeXs}" FontFamily="{StaticResource FontMono}"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{i18n:Tr Key=Settings.About.Version}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </DockPanel>
                    </Border>

                    <!-- 상태 행 (체크 완료 시만) -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding ShowStatus}" Margin="4,0,0,0">
                        <TextBlock Text="{Binding StatusIcon}" FontWeight="SemiBold"
                                   Foreground="{Binding StatusForegroundBrush}"
                                   FontSize="{StaticResource FontSizeS}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{Binding StatusForegroundBrush}"
                                   FontSize="{StaticResource FontSizeS}" />
                    </StackPanel>

                    <!-- What's new 섹션 -->
                    <StackPanel IsVisible="{Binding ShowWhatsNew}" Spacing="6">
                        <TextBlock Text="{Binding WhatsNewTitle}"
                                   FontSize="{StaticResource FontSizeXs}" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <ItemsControl ItemsSource="{Binding WhatsNewItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,2,0,2">
                                        <TextBlock Text="·" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="{StaticResource FontSizeXs}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 업데이트 버튼 (업데이트 있을 때만) -->
                    <StackPanel IsVisible="{Binding ShowUpdateButtons}"
                                Orientation="Horizontal" Spacing="8">
                        <Button Content="{i18n:Tr Key=UpdateCheck.Download}" Classes="BtnPrimary"
                                Command="{Binding OpenDownloadCommand}" />
                        <Button Content="{i18n:Tr Key=UpdateCheck.WhatsNew}" Classes="BtnSecondary"
                                Command="{Binding OpenReleaseNotesCommand}" />
                        <Button Content="{i18n:Tr Key=UpdateCheck.Dismiss}" Classes="BtnSecondary"
                                Command="{Binding DismissUpdateCommand}" />
                    </StackPanel>

                    <!-- Data 행 -->
                    <Border Classes="StatCard">
                        <DockPanel>
                            <TextBlock Text="{Binding DataFolder}" DockPanel.Dock="Right"
                                       FontSize="{StaticResource FontSizeXs}" FontFamily="{StaticResource FontMono}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{i18n:Tr Key=Settings.About.Data}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource TextSecondaryBrush}" Width="60" />
                        </DockPanel>
                    </Border>

                    <!-- Update toggle moved to Security tab (M2-F) -->
                </StackPanel>
            </Border>

            <!-- Links -->
            <Border Classes="Card" Margin="0">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="18" Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Data="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" />
                        <TextBlock Text="{i18n:Tr Key=Settings.Links.Title}"
                                   FontSize="{StaticResource FontSizeM}"
                                   FontWeight="Medium" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <Border Classes="StatCard">
                            <DockPanel>
                                <TextBlock Text="localsynapse.com"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="{i18n:Tr Key=Settings.Links.Website}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </DockPanel>
                        </Border>
                        <Border Classes="StatCard">
                            <DockPanel>
                                <TextBlock Text="github.com/LocalSynapse/LocalSynapse"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource AccentBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{i18n:Tr Key=Settings.Links.GitHub}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </DockPanel>
                        </Border>
                        <Border Classes="StatCard">
                            <DockPanel>
                                <TextBlock Text="Apache License 2.0"
                                           DockPanel.Dock="Right"
                                           FontSize="{StaticResource FontSizeXs}"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{i18n:Tr Key=Settings.About.License}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
